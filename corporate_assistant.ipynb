   "metadata": {},
   "outputs": [],
   "source": [
    "from google import genai\n",
    "from getpass import getpass\n",
    "import datetime\n",
    "# Get API Key\n",
    "api_key = getpass(\"Enter your Gemini API Key: \")\n",
    "client = genai.Client(api_key=api_key)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Welcome message\n",
    "print("\n" + "="*60)\n",
    "print(\"🏢 CORPWRITE - CORPORATE COMMUNICATION ASSISTANT\".center(60))\n",
    "print("="*60)\n",
    "\n",
    "# Get company details\n",
    "company_name = input("\nEnter Company Name: ")\n",
    "hr_name = input("Enter HR/Manager Name: ")\n",
    "designation = input("Enter Your Designation: ")\n",
    "\n",
    "print(f"\n✅ Welcome {hr_name} from {company_name}!")\n",
    "print("-"*60)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Show document types menu\n",
    "print("\n📋 AVAILABLE DOCUMENT TYPES:")\n",
    "print("-"*60)\n",
    "print("1. 📄 Appointment Letter")\n",
    "print("2. 📋 Offer Letter")\n",
    "print("3. 📝 Meeting Minutes")\n",
    "print("4. ⭐ Performance Review")\n",
    "print("5. ⚠️ Termination Letter")\n",
    "print("6. 📤 Resignation Letter")\n",
    "print("7. 📌 Office Memo")\n",
    "print("8. 📅 Meeting Invite")\n",
    "print("9. 📢 Policy Update")\n",
    "print("10. 👋 Welcome Email")\n",
    "print("11. ⚠️ Warning Letter")\n",
    "print("12. 💰 Expense Report")\n",
    "print("-"*60)\n",
    "\n",
    "# Get user input\n",
    "doc_type = input("\nEnter document type (1-12): ")\n",
    "purpose = input("Enter the purpose of this document: ")\n",
    "recipient = input("Enter recipient name/title: ")\n",
    "key_points = input("Enter key points (comma separated): ")\n",
    "tone = input("Enter the tone (Formal/Professional/Friendly/Strict): ")\n",
    "length = input("Enter the length (Short/Medium/Detailed): ")\n",
    "\n",
    "# Get current date\n",
    "current_date = datetime.datetime.now().strftime(\"%B %d, %Y\")\n",
    "\n",
    "# Create document type mapping\n",
    "doc_type_names = {\n",
    "    '1': 'Appointment Letter',\n",
    "    '2': 'Offer Letter',\n",
    "    '3': 'Meeting Minutes',\n",
    "    '4': 'Performance Review',\n",
    "    '5': 'Termination Letter',\n",
    "    '6': 'Resignation Letter',\n",
    "    '7': 'Office Memo',\n",
    "    '8': 'Meeting Invite',\n",
    "    '9': 'Policy Update',\n",
    "    '10': 'Welcome Email',\n",
    "    '11': 'Warning Letter',\n",
    "    '12': 'Expense Report'\n",
    "}\n",
    "\n",
    "doc_name = doc_type_names.get(doc_type, 'Document')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create the prompt\n",
    "prompt = f'''\n",
    "You are a Corporate Communication Assistant for {company_name}.\n",
    "Generate a {doc_name} with the following requirements:\n",
    "\n",
    "Company: {company_name}\n",
    "Generated By: {hr_name} ({designation})\n",
    "Date: {current_date}\n",
    "\n",
    "Document Type: {doc_name}\n",
    "Purpose: {purpose}\n",
    "Recipient: {recipient}\n",
    "Key Points: {key_points}\n",
    "Tone: {tone}\n",
    "Length: {length}\n",
    "\n",
    "Instructions:\n",
    "1. The content must be clear, professional, and grammatically correct\n",
    "2. Use proper corporate formatting with clear sections\n",
    "3. Include appropriate headers, footers, and placeholders where needed\n",
    "4. Add reference numbers using format: {doc_type}/REF/{datetime.datetime.now().strftime('%Y%m%d')}\n",
    "5. Make it suitable for official corporate use\n",
    "6. Include signature blocks with {hr_name} and {designation}\n",
    "7. Add appropriate subject lines and dates\n",
    "8. Maintain consistent professional language throughout\n",
    "\n",
    "Format the document with:\n",
    "- Clear headings and subheadings\n",
    "- Bullet points for lists\n",
    "- Proper spacing\n",
    "- Professional closing\n",
    "'''"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate content\n",
    "print("\n" + "🔄 Generating your document...")\n",
    "print("-"*60)\n",
    "\n",
    "response = client.models.generate_content(\n",
    "    model=\"gemini-2.5-flash\",\n",
    "    contents=prompt\n",
    ")\n",
    "\n",
    "# Display output\n",
    "print("\n✅ GENERATED DOCUMENT")\n",
    "print("="*60)\n",
    "print(response.text)\n",
    "print("="*60)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "save_option = input("\n💾 Do you want to save this document? (yes/no): ")\n",
    "\n",
    "if save_option.lower() == 'yes':\n",
    "    filename = f\"\\{doc_name}_\\{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.txt\"\n",
    "    with open(filename, 'w') as f:\n",
    "        f.write(response.text)\n",
    "    print(f\"✅ Document saved as: {filename}\")\n",
    "\n",
    "print("\n👋 Thank you for using CorpWrite!")\n",
    "print("="*60)"
   ]
  }
 ],
